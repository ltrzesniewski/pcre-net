<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>11.0</LangVersion>
    <Nullable>enable</Nullable>
    <RootNamespace>PCRE.Tests.Integration</RootNamespace>
    <OutputType>Exe</OutputType>
    <PublishAot>true</PublishAot>
    <ControlFlowGuard>Guard</ControlFlowGuard>
    <VerifyReferenceAotCompatibility>true</VerifyReferenceAotCompatibility>
  </PropertyGroup>

  <Choose>
    <When Condition="'$(PcreNetIntegrationTest)' == 'true'">
      <PropertyGroup>
        <DefineConstants>$(DefineConstants);PCRENET_INTEGRATION_TEST</DefineConstants>
      </PropertyGroup>

      <ItemGroup>
        <PackageReference Include="PCRE.NET" Version="$(PackageVersion)" />
      </ItemGroup>
    </When>

    <Otherwise>
      <ItemGroup>
        <ProjectReference Include="../PCRE.NET/PCRE.NET.csproj" />
        <ProjectReference Include="../PCRE.NET.Analyzers/PCRE.NET.Analyzers.csproj" PrivateAssets="all" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
      </ItemGroup>
    </Otherwise>
  </Choose>

  <Import Project="../PCRE.NET/Build/PCRE.NET.targets" Condition="'$(PcreNetIntegrationTest)' != 'true'" />

</Project>
